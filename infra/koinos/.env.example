# Knodel local node profile (safe ports to avoid conflicts)
# Copy to infra/koinos/.env and adjust if needed.

# Distinct project name so compose resources don't collide
COMPOSE_PROJECT_NAME=knodel-koinos-local

# Host ports for local profile (offset from typical defaults)
JSONRPC_PORT=29100
P2P_PORT=29101
BLOCK_STORE_PORT=29102
MEMPOOL_PORT=29103
CHAIN_PORT=29104

# Local data root (separate from any existing node)
DATA_ROOT=./data-local

# IMPORTANT: bootstrap is always local backup
BACKUP_TAR_PATH=/root/koinos_blockchain_backup.tar.gz
