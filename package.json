{
  "name": "knodel",
  "version": "0.9.0",
  "private": true,
  "description": "Knodel desktop base app (Electron + React + TypeScript)",
  "author": "pgarciagon",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch",
    "dev:electron": "wait-on tcp:5173 dist-electron/main.js && node scripts/dev-electron.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:icon:mac": "node scripts/build-mac-icon.js",
    "notarize:preflight": "node scripts/check-notarize-credentials.js",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "package:mac": "npm run notarize:preflight && npm run build:icon && npm run build && electron-builder --mac dmg",
    "package:mac:signed": "npm run build:icon && npm run build && electron-builder --mac dmg",
    "package:mac:dir": "npm run build:icon && npm run build && electron-builder --mac dir",
    "package:mac:unsigned": "npm run build:icon && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "stage:win": "node scripts/stage-bundle-win.js",
    "package:win": "npm run build && npm run stage:win && electron-builder --win nsis",
    "build:web": "vite build",
    "preview:web": "vite preview --host 0.0.0.0 --port 4173",
    "bootstrap:offline": "node backend/src/bootstrap.js",
    "api:local": "node backend/src/server.js",
    "test:backend": "node --test backend/test/*.test.js",
    "submodules:init": "git submodule update --init --recursive",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "ethers": "^5.8.0",
    "express": "^4.21.2",
    "koilib": "^9.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.1"
  }
}
